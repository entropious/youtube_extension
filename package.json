{
  "name": "youtube-panel",
  "displayName": "YouTube Panel",
  "description": "Seamlessly watch YouTube directly in VS Code – tutorials, music, and streams without context switching.",
  "version": "0.1.0",
  "publisher": "entro",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:youtube-panel.view",
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/entropious/youtube_extension.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "youtube-panel-container",
          "title": "YouTube",
          "icon": "media/youtube.svg"
        }
      ]
    },
    "views": {
      "youtube-panel-container": [
        {
          "type": "webview",
          "id": "youtube-panel.view",
          "name": "YouTube Video",
          "icon": "media/icon.png",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "youtube-panel.togglePlay",
        "title": "YouTube: Play/Pause",
        "category": "YouTube"
      },
      {
        "command": "youtube-panel.nextVideo",
        "title": "YouTube: Next Video",
        "category": "YouTube"
      }
    ],
    "keybindings": [
      {
        "command": "youtube-panel.togglePlay",
        "key": "cmd+alt+p",
        "mac": "cmd+alt+p",
        "linux": "ctrl+alt+p",
        "win": "ctrl+alt+p",
        "when": "view.youtube-panel.view.visible"
      },
      {
        "command": "youtube-panel.nextVideo",
        "key": "cmd+alt+o",
        "mac": "cmd+alt+o",
        "linux": "ctrl+alt+o",
        "win": "ctrl+alt+o",
        "when": "view.youtube-panel.view.visible"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "echo \"No automated extension tests configured\""
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.19",
    "typescript": "^5.3.3",
    "eslint": "^8.34.0",
    "@typescript-eslint/eslint-plugin": "^5.52.0",
    "@typescript-eslint/parser": "^5.52.0"
  }
}
